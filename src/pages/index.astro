---
import '../styles/global.css';
import ChatIsland from '../components/ChatIsland.svelte';
import { deriveSuggestedPrompts } from '../lib/prompts';

const personaName = (import.meta.env.PERSONA_NAME || 'Technical Writer').trim() || 'Technical Writer';
const suggestedPrompts = deriveSuggestedPrompts(import.meta.env.SYSTEM_PROMPT);
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
  <meta name="generator" content={Astro.generator} />
  <title>{personaName}</title>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600&family=Instrument+Serif:ital@0;1&family=Inter:wght@400;500&display=swap" rel="stylesheet">
</head>
<body class="bg-[#fcfaf6] text-[#2e2e2e] m-0 p-0 overflow-hidden">
  <ChatIsland client:load personaName={personaName} suggestedPrompts={suggestedPrompts} />
</body>
</html>
