# Techwriter Bot environment template
#
# Copy this file to .env for local development.
# Never commit a filled .env file.

# Deployment identity
# Used as the Cloudflare Pages project name and as the KV key prefix.
PROJECT_NAME=techwriter-bot-client

# App/data schema version stored in KV during deployment.
APP_VERSION=0.0.1

# Cloudflare deployment
# Get account id here: https://dash.cloudflare.com/
# Get API token here: https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Cloudflare Workers AI binding is configured in wrangler.json.
# No API key is needed for Workers AI inside the client's Cloudflare account.
CLOUDFLARE_REMOTE_BINDINGS=false

# AI providers
# Groq API key - get it here: https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras API key - get it here: https://cloud.cerebras.ai/platform/
CEREBRAS_API_KEY=

# Gemini API key - get it here: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# NVIDIA API key - get it here: https://build.nvidia.com/
NVIDIA_API_KEY=

# OpenRouter API key - get it here: https://openrouter.ai/settings/keys
OPENROUTER_API_KEY=

# Search providers
# Tavily API key - get it here: https://app.tavily.com/
TAVILY_API_KEY=

# Exa API key - get it here: https://dashboard.exa.ai/api-keys
EXA_API_KEY=

# Abuse protection
# Cloudflare Turnstile secret - get it here:
# https://dash.cloudflare.com/?to=/:account/turnstile
TURNSTILE_SECRET_KEY=

# Comma-separated IPs that bypass reputation throttling during development.
DEV_IPS=127.0.0.1,::1

# Phase 1 safety limits
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_DAY=500
CHAT_MAX_CHARS=4000
MAX_REQUEST_BODY_BYTES=5242880
HEALTH_PING_TIMEOUT_MS=5000
